<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_activity_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_item_background"
    android:padding="8dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Friend Avatar (pre-cropped to circle in ImageDownloader) -->
    <ImageView
        android:id="@+id/friend_image"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_person"
        android:scaleType="centerCrop"
        android:layout_marginEnd="10dp" />

    <!-- Info Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Friend Name -->
        <TextView
            android:id="@+id/friend_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Friend Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Status: "Listening now" (green) or time ago (tertiary) -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listening now"
            android:textSize="9sp"
            android:textColor="@color/widget_accent"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Track / Playlist Name -->
        <TextView
            android:id="@+id/track_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Name"
            android:textSize="11sp"
            android:textColor="@color/widget_text_secondary"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Artist / Context -->
        <TextView
            android:id="@+id/friend_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textSize="9sp"
            android:textColor="@color/widget_text_tertiary"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Album Art (pre-rounded in ImageDownloader) -->
    <ImageView
        android:id="@+id/album_art"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/default_album_art"
        android:scaleType="centerCrop"
        android:background="@color/widget_item_background"
        android:layout_marginStart="8dp" />

</LinearLayout>
