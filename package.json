{
  "name": "playtivity-build-tools",
  "version": "1.0.0",
  "description": "Local build tools for Playtivity APK with Node.js scripts",
  "scripts": {
    "build": "node scripts/build-apk.js",
    "build:patch": "node scripts/build-apk.js patch",
    "build:minor": "node scripts/build-apk.js minor",
    "build:major": "node scripts/build-apk.js major",
    "release": "node scripts/release-apk.js",
    "release:patch": "node scripts/release-apk.js patch",
    "release:minor": "node scripts/release-apk.js minor",
    "release:major": "node scripts/release-apk.js major",
    "release:apk-only": "node scripts/release-apk.js --no-bundle",
    "nightly": "node scripts/nightly.js",
    "nightly:local": "node scripts/nightly.js --skip-github",
    "nightly:stable": "node scripts/nightly.js --stable",
    "nightly:clean": "node scripts/nightly.js --clean",
    "nightly:keep-10": "node scripts/nightly.js --keep 10",
    "nightly:promote": "node scripts/nightly-release.js",
    "nightly:promote-patch": "node scripts/nightly-release.js patch",
    "nightly:promote-minor": "node scripts/nightly-release.js minor",
    "nightly:promote-major": "node scripts/nightly-release.js major",
    "list": "node scripts/list-commands.js",
    "help": "node scripts/build-apk.js --help",
    "help:release": "node scripts/release-apk.js --help",
    "help:nightly": "node scripts/nightly.js --help",
    "help:nightly-promote": "node scripts/nightly-release.js --help",
    "test:identity": "node tests/user-identity.test.js"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "author": "Playtivity Team",
  "license": "MIT",
  "keywords": [
    "android",
    "apk",
    "flutter",
    "build",
    "release",
    "nightly",
    "github"
  ]
}
